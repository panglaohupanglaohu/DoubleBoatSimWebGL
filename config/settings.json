{
  "api": {
    "backend": {
      "host": "127.0.0.1",
      "port": 8000,
      "base_url": "http://127.0.0.1:8000"
    },
    "frontend": {
      "host": "127.0.0.1",
      "port": 5173,
      "base_url": "http://127.0.0.1:5173"
    }
  },
  "llm": {
    "local": "http://127.0.0.1:11434/v1",
    "provider": "local"
  },
  "websocket": {
    "url": "ws://127.0.0.1:8765"
  },
  "environment": "development",
  "debug": true,
  "lakehouse": {
    "buffer_max_size": 1,
    "store_type": "sqlite",
    "analytics_cache_dir": "storage/analytics_cache",
    "store_config": {
      "db_path": "storage/poseidon_events.db",
      "storage_path": "storage/events"
    },
    "cloud_type": "local",
    "cloud_config": {
      "storage_path": "storage/cloud_sync",
      "bucket_name": "doubleboat-events",
      "region": "us-east-1",
      "prefix": "events/",
      "endpoint_url": null,
      "addressing_style": "path",
      "verify_ssl": true,
      "auto_create_bucket": false
    }
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  }
}
